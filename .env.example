# Copy this file to .env and fill it in.
#
# Fields tagged [REQUIRED] must be set or the bot refuses to start; everything else has a
# sensible default and can be left as-is.

# --- Discord credentials ---
# [REQUIRED] Bot token from https://discord.com/developers/applications -> Bot
DISCORD_TOKEN=

# [REQUIRED] Application (client) ID from the General Information page
CLIENT_ID=

# Guild (server) ID where slash commands are registered for instant updates.
# Leave empty to register globally (can take up to 1h to propagate). Recommended when the
# bot only serves one server.
GUILD_ID=

# Comma-separated Discord user IDs allowed to run /admin commands.
# Empty = nobody can use /admin.
OWNER_IDS=

# --- Runtime ---
# Where the SQLite DB and backups live. In production systemd sets this to the
# StateDirectory (/var/lib/discord-all-in). For local dev it defaults to ./data.
# DATA_DIR=/var/lib/discord-all-in

# pretty | json  (pretty is nicer in a terminal, json for the systemd journal)
LOG_FORMAT=pretty
LOG_LEVEL=info

# --- Economy: earning ---
# All amounts are whole chips. Everything here has a sensible default baked in,
# so you only need to uncomment a line to override it. Booleans accept
# true/false/1/0/yes/no/on/off.

# One-time grant the first time a user interacts with the bot.
# WELCOME_BONUS=1000

# Chips granted per tick to eligible members in voice, and how often the loop runs.
# VOICE_AMOUNT_PER_TICK=5
# VOICE_TICK_SECONDS=60

# Anti-farm requirements — all OFF by default (permissive). Tighten them only if you
# want to discourage idle/solo farming:
#
# Minimum non-bot humans in the channel before anyone earns. 1 = "just be in a
# channel" (no requirement); set to 2+ to stop solo farming.
# VOICE_MIN_HUMANS=1
#
# Whether self-muted / self-deafened members still earn. Default true (they do);
# set to false to require an active, unmuted presence.
# VOICE_PAY_WHILE_MUTED=true
# VOICE_PAY_WHILE_DEAFENED=true
#
# The server's Inactive/AFK channel is ALWAYS excluded automatically (read from the
# Discord API). Use this only to exclude additional channels from earning, e.g. a
# music or streaming room. Comma-separated channel IDs.
# VOICE_EXCLUDED_CHANNELS=123456789012345678,234567890123456789
